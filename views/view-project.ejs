<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Projects</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg, #22223b, #4a4e69 65%);
      min-height: 100vh;
      color: #232946;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      padding: 24px 0;
      overflow-x: hidden;
    }
    .container {
      max-width: 1200px;
      width: 90%;
      background: #f7f7fb;
      border-radius: 16px;
      box-shadow: 0 6px 24px rgba(34,34,59,0.07);
      padding: 24px;
      margin: 0 auto;
    }
    h1 {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 16px;
      color: #22223b;
      text-align: center;
      letter-spacing: 1px;
    }
    .message {
      padding: 10px;
      border-radius: 8px;
      text-align: center;
      margin-bottom: 16px;
      font-weight: 500;
    }
    .error { background: #ffe6e6; color: #e63946; }
    .success { background: #e6ffed; color: #2ecc71; }

    .search-form {
      display: flex;
      justify-content: center;
      margin-bottom: 16px;
      flex-wrap: wrap;
      gap: 8px;
    }
    .search-form input {
      padding: 10px;
      border: 1px solid #e0e4ea;
      border-radius: 8px;
      font-size: 1rem;
      width: 100%;
      max-width: 250px;
    }
    .search-form button {
      padding: 10px 16px;
      border: none;
      border-radius: 8px;
      background: #4f8cff;
      color: #fff;
      font-weight: 600;
      cursor: pointer;
    }

    .nav-links {
      margin-bottom: 16px;
      text-align: center;
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 12px;
    }
    .nav-links a {
      color: #4f8cff;
      text-decoration: none;
      font-weight: 600;
    }

    /* Table */
    .project-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0 8px;
      margin-top: 12px;
    }
    th, td {
      padding: 12px;
      text-align: left;
      background: #fff;
      max-width: 200px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    th {
      background: #e9ecef;
      font-weight: 600;
      color: #232946;
    }
    td img {
      border-radius: 6px;
      object-fit: cover;
      width: 80px;
      height: 50px;
      background: #e9ecef;
    }

    /* Cards for Mobile */
    .project-cards {
      display: none;
      flex-direction: column;
      gap: 16px;
      margin-top: 12px;
    }
    .project-card {
      background: #fff;
      border-radius: 8px;
      padding: 16px;
      box-shadow: 0 2px 8px rgba(34,34,59,0.1);
    }
    .project-card img {
      border-radius: 6px;
      object-fit: cover;
      width: 100%;
      height: 160px;
      background: #e9ecef;
    }

    .action-buttons {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    button, a.edit {
      padding: 8px 16px;
      border: none;
      border-radius: 6px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
    }
    button.delete { background: #e63946; color: white; }
    a.edit { background: #4f8cff; color: white; }

    @media (max-width: 768px) {
      .project-table { display: none; }
      .project-cards { display: flex; }
    }
    @media (min-width: 769px) {
      .project-table { display: table; }
      .project-cards { display: none; }
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Projects</h1>

    <% if (message) { %>
      <p class="message error"><%= message %></p>
    <% } %>

    <div class="search-form">
      <form action="/api/projects/view" method="GET">
        <input type="text" name="search" placeholder="Search by name or title..." value="<%= searchQuery || '' %>">
        <button type="submit">Search</button>
      </form>
    </div>

    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/api/projects/create">Add Project</a>
      <a href="/api/projects/json">JSON View</a>
    </div>

    <!-- Desktop Table -->
    <table class="project-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Title</th>
          <th>Description</th>
          <th>Project URL</th>
          <th>Code View URL</th>
          <th>Image</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (projects.length === 0) { %>
          <tr><td colspan="7" style="text-align:center;">No projects found.</td></tr>
        <% } else { %>
          <% projects.forEach(function(project) { %>
            <tr>
              <td title="<%= project.name %>"><%= project.name %></td>
              <td title="<%= project.title %>"><%= project.title %></td>
              <td title="<%= project.description %>"><%= project.description %></td>
              <td><a href="<%= project.projectsUrl %>" target="_blank"><%= project.projectsUrl %></a></td>
              <td><a href="<%= project.projectCodeViewurl %>" target="_blank"><%= project.projectCodeViewurl %></a></td>
              <td>
                <% if (project.projectImg) { %>
                  <img src="<%= project.projectImg %>" 
                       alt="<%= project.name %>" 
                       loading="lazy"
                       onerror="this.src='https://via.placeholder.com/80x50?text=Image+Not+Found';">
                <% } else { %>
                  <img src="https://via.placeholder.com/80x50?text=No+Image" alt="No image">
                <% } %>
              </td>
              <td class="action-buttons">
                <a href="/api/projects/edit/<%= project._id %>" class="edit">Edit</a>
                <button class="delete" data-id="<%= project._id %>">Delete</button>
              </td>
            </tr>
          <% }); %>
        <% } %>
      </tbody>
    </table>

    <!-- Mobile Cards -->
    <div class="project-cards">
      <% projects.forEach(function(project) { %>
        <div class="project-card">
          <% if (project.projectImg) { %>
            <img src="<%= project.projectImg %>" 
                 alt="<%= project.name %>" 
                 loading="lazy"
                 onerror="this.src='https://via.placeholder.com/300x160?text=Image+Not+Found';">
          <% } else { %>
            <img src="https://via.placeholder.com/300x160?text=No+Image" alt="No image">
          <% } %>
          
          <p><strong>Name:</strong> <%= project.name %></p>
          <p><strong>Title:</strong> <%= project.title %></p>
          <p><strong>Description:</strong> <%= project.description %></p>
          <p><strong>Project URL:</strong> <a href="<%= project.projectsUrl %>" target="_blank"><%= project.projectsUrl %></a></p>
          <p><strong>Code URL:</strong> <a href="<%= project.projectCodeViewurl %>" target="_blank"><%= project.projectCodeViewurl %></a></p>
          
          <div class="action-buttons">
            <a href="/api/projects/edit/<%= project._id %>" class="edit">Edit</a>
            <button class="delete" data-id="<%= project._id %>">Delete</button>
          </div>
        </div>
      <% }); %>
    </div>
  </div>

  <!-- Delete Confirmation Dialog (kept same) -->
  <div class="overlay" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:999;"></div>
  <div class="confirm-dialog" style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); background:white; padding:20px; border-radius:10px; z-index:1000; text-align:center;">
    <p>Are you sure you want to delete this project?</p>
    <div style="margin-top:15px;">
      <button class="confirm" style="background:#e63946; color:white; padding:10px 20px; margin:5px;">Yes, Delete</button>
      <button class="cancel" style="background:#6b7280; color:white; padding:10px 20px; margin:5px;">Cancel</button>
    </div>
  </div>

  <script>
    // Delete functionality
    let currentId = null;
    const overlay = document.querySelector('.overlay');
    const dialog = document.querySelector('.confirm-dialog');

    document.querySelectorAll('.delete').forEach(btn => {
      btn.addEventListener('click', () => {
        currentId = btn.dataset.id;
        overlay.style.display = 'block';
        dialog.style.display = 'block';
      });
    });

    document.querySelector('.cancel').addEventListener('click', () => {
      overlay.style.display = 'none';
      dialog.style.display = 'none';
    });

    document.querySelector('.confirm').addEventListener('click', async () => {
      if (!currentId) return;
      try {
        const res = await fetch(`/api/projects/delete/${currentId}`, { method: 'POST' });
        if (res.redirected) window.location.href = res.url;
      } catch (e) {
        alert('Failed to delete');
      }
    });
  </script>
</body>
</html>
