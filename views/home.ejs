<!DOCTYPE html>
<html>
<head>
  <title>Portfolio Home</title>
  <style>
    /* (Keep your existing styles - I'm only showing the important part) */
    .dashboard {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 25px;
      margin-top: 30px;
    }
    .card {
      background: #232946;
      border-radius: 15px;
      padding: 25px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    }
    .card h3 { color: #ffe066; margin-bottom: 15px; }
    .card-links a {
      display: block;
      padding: 10px;
      background: #4f8cff;
      color: white;
      text-decoration: none;
      margin: 8px 0;
      border-radius: 8px;
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Portfolio Dashboard</h1>

    <div class="dashboard">
      <!-- Existing Cards -->
      <div class="card">
        <h3>Projects</h3>
        <div class="card-links">
          <a href="/api/projects/view">View Projects</a>
          <a href="/api/projects/json">JSON</a>
          <a href="/api/projects/create">Add Project</a>
        </div>
      </div>

      <div class="card">
        <h3>Skills</h3>
        <div class="card-links">
          <a href="/api/skills/view">View Skills</a>
          <a href="/api/skills/json">JSON</a>
          <a href="/api/skills/create">Add Skill</a>
        </div>
      </div>

      <div class="card">
        <h3>About</h3>
        <div class="card-links">
          <a href="/api/about/view">View About</a>
          <a href="/api/about/json">JSON</a>
          <a href="/api/about/create">Add About</a>
        </div>
      </div>

      <!-- New Database Card -->
      <div class="card">
        <h3>Extra Database</h3>
        <div class="card-links">
          <a href="/api/database/view">View All Entries</a>
          <a href="/api/database/create">Add New Entry</a>
          <a href="/api/database/json">JSON View</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
