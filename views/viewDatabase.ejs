<!DOCTYPE html>
<html>
<head>
  <title>Database Entries</title>
  <style>
    body { font-family: Arial; background: #22223b; color: #fff; padding: 20px; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 12px; border: 1px solid #444; text-align: left; }
    img { width: 80px; border-radius: 8px; }
  </style>
</head>
<body>
  <h1>Portfolio Database</h1>
  <a href="/api/database/create">+ Add New Entry</a> | 
  <a href="/">Home</a>

  <table>
    <tr>
      <th>Title</th>
      <th>Category</th>
      <th>Description</th>
      <th>Image</th>
      <th>Link</th>
      <th>Actions</th>
    </tr>
    <% items.forEach(item => { %>
      <tr>
        <td><%= item.title %></td>
        <td><%= item.category %></td>
        <td><%= item.description.substring(0, 100) %>...</td>
        <td>
          <% if (item.image) { %>
            <img src="<%= item.image %>" alt="">
          <% } %>
        </td>
        <td>
          <% if (item.link) { %>
            <a href="<%= item.link %>" target="_blank"><%= item.linkText || 'Link' %></a>
          <% } %>
        </td>
        <td>
          <a href="/api/database/edit/<%= item._id %>">Edit</a> |
          <form action="/api/database/delete/<%= item._id %>" method="POST" style="display:inline">
            <button type="submit" onclick="return confirm('Delete?')">Delete</button>
          </form>
        </td>
      </tr>
    <% }); %>
  </table>
</body>
</html>
