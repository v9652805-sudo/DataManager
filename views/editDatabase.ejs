<!DOCTYPE html>
<html>
<head>
  <title><%= isEdit ? 'Edit' : 'Add' %> Entry</title>
  <style>
    body { font-family: Arial, sans-serif; background: #22223b; color: #fff; padding: 30px; }
    .container { max-width: 700px; margin: auto; background: #2a2d4a; padding: 30px; border-radius: 15px; }
    input, select, textarea { width: 100%; padding: 12px; margin: 10px 0; border-radius: 8px; }
    button { padding: 12px 30px; background: #4f8cff; color: white; border: none; border-radius: 8px; cursor: pointer; }
    .error { color: #ff6b6b; background: #4a2a2a; padding: 10px; border-radius: 8px; }
  </style>
</head>
<body>
  <div class="container">
    <h1><%= isEdit ? 'Edit' : 'Add New' %> Information</h1>
    
    <% if (message) { %>
      <p class="error"><%= message %></p>
    <% } %>

    <form action="<%= isEdit ? '/api/database/update/' + item._id : '/api/database/create' %>" 
          method="POST" enctype="multipart/form-data">
      
      <input type="text" name="title" placeholder="Title" value="<%= item.title || '' %>" required>
      
      <select name="category">
        <option value="about" <%= item.category === 'about' ? 'selected' : '' %>>About</option>
        <option value="experience" <%= item.category === 'experience' ? 'selected' : '' %>>Experience</option>
        <option value="education" <%= item.category === 'education' ? 'selected' : '' %>>Education</option>
        <option value="achievement" <%= item.category === 'achievement' ? 'selected' : '' %>>Achievement</option>
        <option value="certificate" <%= item.category === 'certificate' ? 'selected' : '' %>>Certificate</option>
        <option value="other" <%= item.category === 'other' ? 'selected' : '' %>>Other</option>
      </select>

      <textarea name="description" rows="6" placeholder="Description" required><%= item.description || '' %></textarea>
      
      <input type="file" name="image" accept="image/*">
      <input type="text" name="link" placeholder="Link (optional)" value="<%= item.link || '' %>">
      <input type="text" name="linkText" placeholder="Link Text" value="<%= item.linkText || '' %>">
      <input type="number" name="order" placeholder="Display Order" value="<%= item.order || 0 %>">

      <button type="submit"><%= isEdit ? 'Update Entry' : 'Create Entry' %></button>
    </form>
  </div>
</body>
</html>
