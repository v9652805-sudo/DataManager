<!DOCTYPE html>
<html>
<head>
  <title><%= isEdit ? 'Edit' : 'Add' %> Database Entry</title>
  <style>
    body { font-family: 'Inter', sans-serif; background: #22223b; color: #fff; padding: 30px; }
    .form-container { max-width: 700px; margin: 0 auto; background: #2a2d4a; padding: 30px; border-radius: 15px; }
    input, textarea, select { width: 100%; padding: 12px; margin: 10px 0; border-radius: 8px; border: none; }
    button { padding: 12px 25px; background: #4f8cff; color: white; border: none; border-radius: 8px; cursor: pointer; }
  </style>
</head>
<body>
  <div class="form-container">
    <h1><%= isEdit ? 'Edit' : 'Add New' %> Information</h1>
    <% if (message) { %><p style="color:red"><%= message %></p><% } %>

    <form action="<%= isEdit ? '/api/database/update/' + item._id : '/api/database/create' %>" 
          method="POST" enctype="multipart/form-data">

      <input type="text" name="title" placeholder="Title (e.g. My Education)" value="<%= item.title || '' %>" required>
      
      <select name="category">
        <option value="about" <%= item.category === 'about' ? 'selected' : '' %>>About</option>
        <option value="experience" <%= item.category === 'experience' ? 'selected' : '' %>>Experience</option>
        <option value="education" <%= item.category === 'education' ? 'selected' : '' %>>Education</option>
        <option value="achievement" <%= item.category === 'achievement' ? 'selected' : '' %>>Achievement</option>
        <option value="certificate" <%= item.category === 'certificate' ? 'selected' : '' %>>Certificate</option>
        <option value="other" <%= item.category === 'other' ? 'selected' : '' %>>Other</option>
      </select>

      <textarea name="description" rows="6" placeholder="Description / Content" required><%= item.description || '' %></textarea>
      
      <input type="file" name="image" accept="image/*">
      
      <input type="text" name="link" placeholder="Link (optional)" value="<%= item.link || '' %>">
      <input type="text" name="linkText" placeholder="Link Text (e.g. View Certificate)" value="<%= item.linkText || '' %>">
      
      <input type="number" name="order" placeholder="Display Order" value="<%= item.order || 0 %>">

      <button type="submit"><%= isEdit ? 'Update' : 'Add to Database' %></button>
    </form>
  </div>
</body>
</html>
